# AI Auditor Environment Variables Template
# Copy this file to .env and fill in your actual values

# LLM Configuration
AI_AUDITOR_LLM_MODEL=llama3.2:3b-instruct-q4_0
AI_AUDITOR_LLM_API_BASE=http://localhost:11434
AI_AUDITOR_LLM_TIMEOUT=120
AI_AUDITOR_LLM_SECTION_TIMEOUT=60

# Analysis Configuration  
AI_AUDITOR_MAX_FILE_SIZE=52428800
AI_AUDITOR_MAX_PYTHON_FILES=1000
AI_AUDITOR_OUTPUT_DIRECTORY=audit_reports

# Logging Configuration
AI_AUDITOR_LOG_LEVEL=INFO
AI_AUDITOR_LOG_FORMAT=json
AI_AUDITOR_ENABLE_CONSOLE_OUTPUT=true

# Security Configuration
AI_AUDITOR_ENABLE_SECRET_DETECTION=true
AI_AUDITOR_MAX_PATH_LENGTH=200

# Performance Configuration
AI_AUDITOR_ENABLE_PARALLEL_PROCESSING=true
AI_AUDITOR_MAX_WORKERS=4
AI_AUDITOR_MEMORY_LIMIT_MB=1024

# MCP Configuration
AI_AUDITOR_ENABLE_MCP_VALIDATION=true
AI_AUDITOR_MCP_COMPLIANCE_LEVEL=PARTIAL
AI_AUDITOR_REQUIRE_MCP_STRUCTURE=true
